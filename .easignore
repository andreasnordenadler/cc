# EAS archive rules for the SQC monorepo.
# This mirrors .gitignore, except the generated Android native source is included
# so remote EAS builds use the committed Expo package/version configuration.

/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

/coverage
/playwright-report/
/test-results/
/.next/
/out/
/build
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.env*
.vercel
*.tsbuildinfo
next-env.d.ts
CC_GIT_TEST=1
apps/mobile/node_modules

# Never upload signing credentials.
apps/mobile/credentials.json
apps/mobile/credentials/
*.jks
*.keystore

# Include apps/mobile/android source; exclude generated native build state.
!apps/mobile/android/
!apps/mobile/android/**
apps/mobile/.expo/
apps/mobile/android/.gradle/
apps/mobile/android/build/
apps/mobile/android/app/build/
apps/mobile/android/app/.cxx/

/tmp/
/.worktrees/
/.learnings/
/artifacts/
/dist/
apps/mobile/dist*/
public/downloads/*.apk
public/downloads/*.apk.sha256
/memory/
/state/
app.json
tmp-seals.jpg
/docs/SQC_DAILY_THREE_LANE_REPORT_*.md
/docs/CHESSCOM_POST_PARITY_*_2026-04-*.md
/docs/SQC_MOBILE_BEST_RELEASE_CANDIDATE_*.md
/docs/SQC_MOBILE_COMPLETION_CELEBRATION_SPEC_*.md
/docs/SQC_MOBILE_DEVELOPMENT_STATUS_CHECKPOINT_*.md
/docs/SQC_MOBILE_TELEGRAM_HANDOFF_*.md
/docs/SQC_PHOTOREALISTIC_COAT_OF_ARMS_EXPERIMENT_*.md
/docs/SQC_REDDIT_OPENCLAW_AGENT_POSTING_PLAN_*.md
/docs/SQC_REDDIT_OPENCLAW_POST_DRAFT_*.md
/public/badges/v5/
/public/sqc-logo-v*.png
/public/stamps/quest-complete-premium-red-wax-sqc-v*.png
/public/stamps/quest-complete-real-red-wax-sqc-v*.png
/public/stamps/quest-complete-red-wax-sqc-logo-v*.png
/scripts/seed-sqc-realistic-community-data.cjs
/.clerk/
