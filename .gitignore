# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

CC_GIT_TEST=1
.env*.local

apps/mobile/node_modules

# Mobile signing credentials must never be committed
apps/mobile/credentials.json
apps/mobile/credentials/
*.jks
*.keystore

# Expo/mobile local generated artifacts
apps/mobile/.expo/
apps/mobile/android/

# local QA/release artifacts and agent notes
/tmp/
/.worktrees/
/.learnings/
/artifacts/
/dist/
apps/mobile/dist*/
public/downloads/*.apk
public/downloads/*.apk.sha256

