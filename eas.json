{
  "cli": {
    "version": ">= 15.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_SQC_API_BASE_URL": "https://sidequestchess.com"
      }
    },
    "android-alpha": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_SQC_API_BASE_URL": "https://sidequestchess.com"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_SQC_API_BASE_URL": "https://sidequestchess.com"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_SQC_API_BASE_URL": "https://sidequestchess.com"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
