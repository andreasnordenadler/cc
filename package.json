{
  "name": "cc",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "quest:release-gate": "node scripts/check-release-ready-quests.mjs && node scripts/check-custom-side-quest-launch-ready.mjs",
    "deploy:prod:guard": "pnpm quest:release-gate && node scripts/deploy-production-guard.mjs",
    "deploy:prod": "pnpm deploy:prod:guard && vercel --prod --yes",
    "mobile:release": "node scripts/mobile-release.mjs",
    "mobile:release:check": "node scripts/mobile-release.mjs --no-bump --skip-build",
    "mobile:release:candidate-check": "node scripts/check-mobile-release-candidate.mjs",
    "mobile:release:device-install": "node scripts/install-mobile-release-candidate.mjs",
    "mobile:release:github": "node scripts/mobile-release.mjs --github-release",
    "qa:multiplayer:local": "node scripts/multiplayer-qa-local.cjs",
    "qa:launch:local": "node scripts/launch-qa-local.cjs",
    "qa:launch:providers": "node scripts/launch-qa-providers.mjs",
    "admin:grant-analytics": "node scripts/grant-sqc-admin.cjs",
    "sdk:smoke": "node testing-sdk/smoke.mjs"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.4.2",
    "chess.js": "^1.4.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "playwright": "^1.60.0",
    "typescript": "^5"
  }
}
